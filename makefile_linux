CXX      := g++
CXXFLAGS := -std=c++17 -Wall -Wextra -O2 -Isrc -MMD -MP
TARGET   := textrpg
BUILD_DIR := build

SRCS := \
  src/main.cpp \
  src/domain/inventory.cpp \
  src/domain/enemy.cpp \
  src/domain/player.cpp \
  src/data/monsters.cpp \
  src/data/weapons.cpp \
  src/data/items.cpp \
  src/data/upgrades.cpp \
  src/game/item_service.cpp \
  src/game/battle_service.cpp \
  src/game/shop_service.cpp \
  src/tui/terminal.cpp \
  src/tui/renderer.cpp \
  src/tui/screens.cpp \
  src/tui/screens2.cpp \
  src/tui/screens3.cpp \
  src/tui/app.cpp

# Ubah object jadi masuk ke build/
OBJS := $(patsubst src/%.cpp,$(BUILD_DIR)/%.o,$(SRCS))
DEPS := $(OBJS:.o=.d)

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

# Rule compile (auto bikin folder dalam build/)
$(BUILD_DIR)/%.o: src/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c -o $@ $<

clean:
	rm -rf $(BUILD_DIR) $(TARGET)

-include $(DEPS)

.PHONY: all clean
