src/tui/terminal.i: src/tui/terminal.cpp.i
.PHONY : src/tui/terminal.i

# target to preprocess a source file
src/tui/terminal.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/textrpg.dir/build.make CMakeFiles/textrpg.dir/src/tui/terminal.cpp.i
.PHONY : src/tui/terminal.cpp.i

src/tui/terminal.s: src/tui/terminal.cpp.s
.PHONY : src/tui/terminal.s

# target to generate assembly for a file
src/tui/terminal.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/textrpg.dir/build.make CMakeFiles/textrpg.dir/src/tui/terminal.cpp.s
.PHONY : src/tui/terminal.cpp.s

